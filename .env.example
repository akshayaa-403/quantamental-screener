# Copy this file to .env and adjust as needed:  cp .env.example .env
# All variables are optional; sensible defaults are used when unset.

# --- Redis cache (see config/settings.py: RedisSettings) ---
# Caching is OFF by default. Set REDIS_ENABLED=true and point REDIS_URL at a
# running Redis (docker-compose provides one) to enable it.
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_DEFAULT=3600
REDIS_TTL_PRICE=14400        # 4 hours
REDIS_TTL_SENTIMENT=604800   # 7 days
REDIS_TTL_FACTOR=86400       # 1 day

# --- Universe selection (config/settings.py: UniverseSettings) ---
UNIVERSE_SIZE=50
UNIVERSE_MIN_MARKET_CAP=5000000000
UNIVERSE_MIN_VOLUME=1000000

# --- Factor weights (config/settings.py: FactorWeights) ---
# These drive the composite score in the CLI. They need not sum to 1.
FACTOR_MOMENTUM=0.4
FACTOR_SENTIMENT=0.3
FACTOR_VOLUME=0.2
FACTOR_VOLATILITY=0.1

# --- Backtest (config/settings.py: BacktestSettings) ---
BACKTEST_PERIOD=1y
BACKTEST_REBALANCE_FREQ=5
BACKTEST_TOP_N_STOCKS=10
# Annualized risk-free rate used in the Sharpe ratio (e.g. 0.045 for 4.5%).
BACKTEST_RISK_FREE_RATE=0.0

# --- External data / news API keys (all optional) ---
# NewsAPI (https://newsapi.org) powers real headline retrieval; without it the
# app falls back to yfinance news.
NEWS_API_KEY=
FINNHUB_API_KEY=
ALPHA_VANTAGE_API_KEY=
POLYGON_API_KEY=

# --- Logging (utils/logging_utils.py) ---
LOG_LEVEL=INFO
LOG_TO_FILE=false

# --- Sentiment ---
# When true, the CLI replaces real sentiment with seeded random mock scores
# (useful for demos / offline runs). Leave false to use real sentiment.
USE_MOCK_SENTIMENT=false
